# ──────────────────────────────────────────────────────────────────────────────
# Worktree — Environment Variables
# Copy to .env.local for local development (gitignored)
# Production values are injected via ECS Task Definition / GitHub Actions secrets
# ──────────────────────────────────────────────────────────────────────────────

# ─── App Core ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3005
BACKEND_PORT=5005

# ─── Auth (NextAuth v5) ───────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=change-me-32-chars-minimum-secret-here
NEXTAUTH_URL=http://localhost:3005

# ─── DynamoDB ─────────────────────────────────────────────────────────────────
# Local dev: points to dynamodb-local container on non-default port 8100
# Production: leave DYNAMODB_ENDPOINT unset — SDK uses real AWS DynamoDB
DYNAMODB_ENDPOINT=http://dynamodb-local:8100
DYNAMODB_TABLE_NAME=worktree-local
AWS_REGION=us-east-1

# ─── Redis ────────────────────────────────────────────────────────────────────
# Local dev: Redis container on non-default port 6380
# Production: ElastiCache endpoint (rediss:// for TLS)
REDIS_URL=redis://redis:6380

# ─── S3 Storage (LocalStack for local dev) ────────────────────────────────────
# Local dev: LocalStack on non-default port 4510 — no real AWS credentials needed
# Production: leave S3_ENDPOINT unset — SDK uses real AWS S3 with IAM credentials
S3_ENDPOINT=http://localstack:4510
S3_BUCKET=worktree-local
# LocalStack accepts any non-empty credential values
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# Production S3 (uncomment and fill for production):
# S3_BUCKET=worktree-prod
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# ─── Pinecone (Vector Search) ─────────────────────────────────────────────────
# Option A — real free-tier API (requires internet, data persists):
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=worktree-local

# Option B — local container (offline, ephemeral, run with --profile pinecone):
# PINECONE_API_KEY=local
# PINECONE_HOST=http://pinecone-local:5080
# PINECONE_INDEX_NAME=worktree-local

# ─── Frontend Public Vars ──────────────────────────────────────────────────────
# Leave empty in local dev — Next.js proxy rewrites /api to localhost
NEXT_PUBLIC_API_URL=
# WS server (browser connects to host port)
NEXT_PUBLIC_WS_URL=ws://localhost:1234
