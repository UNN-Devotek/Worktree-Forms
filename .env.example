# =============================================================================
# Worktree — Environment Variables
# Copy to .env.local for local development. Never commit .env.local.
# =============================================================================

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3005
BACKEND_PORT=5005

# ─── Auth.js (NextAuth v5) ────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=change-me-to-a-32-plus-character-random-secret
NEXTAUTH_URL=http://localhost:3005
# AUTH_TRUST_HOST=true  # needed behind reverse proxy / ECS ALB

# ─── AWS / DynamoDB ────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# Main application table
DYNAMODB_TABLE_NAME=worktree-local
DYNAMODB_REGION=us-east-1
# LOCAL DEV ONLY — omit in production (absence = real AWS DynamoDB)
DYNAMODB_ENDPOINT=http://dynamodb-local:8100

# Auth sessions table (separate table, different key schema from app table)
DYNAMODB_AUTH_TABLE_NAME=worktree-auth-local

# ─── S3 / Storage ─────────────────────────────────────────────────────────────
S3_BUCKET=worktree-local
# LOCAL DEV ONLY — omit in production (absence = real AWS S3)
S3_ENDPOINT=http://localstack:4510

# ─── Redis / ElastiCache ──────────────────────────────────────────────────────
# Local dev: redis://redis:6380 (Docker service name, non-default port)
# Production: rediss://<elasticache-endpoint>:6379
REDIS_URL=redis://redis:6380

# ─── Pinecone Vector Search ───────────────────────────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=worktree-local
# LOCAL DEV ONLY with --profile pinecone flag:
# PINECONE_HOST=http://pinecone-local:5080

# ─── AI ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here

# ─── Public / Client-side Variables ───────────────────────────────────────────
# These are baked into the Next.js bundle at build time
NEXT_PUBLIC_API_URL=http://localhost:5005
NEXT_PUBLIC_WS_URL=ws://localhost:1234
NEXT_PUBLIC_ENABLE_DEV_LOGIN=true

# =============================================================================
# PRODUCTION OVERRIDES (set in ECS Task Definition / GitHub Secrets)
# =============================================================================
# NODE_ENV=production
# NEXTAUTH_URL=https://worktree.pro
# AUTH_SECRET=<32+-char secret>
# AWS_REGION=us-east-1
# DYNAMODB_TABLE_NAME=worktree-prod
# DYNAMODB_AUTH_TABLE_NAME=worktree-auth-prod
# S3_BUCKET=worktree-prod
# REDIS_URL=rediss://<elasticache-endpoint>:6379
# PINECONE_API_KEY=<real key>
# PINECONE_INDEX_NAME=worktree-prod
# OPENAI_API_KEY=<real key>
# NEXT_PUBLIC_API_URL=https://worktree.pro
# NEXT_PUBLIC_WS_URL=wss://worktree.pro/ws
# NOTE: Do NOT set DYNAMODB_ENDPOINT, S3_ENDPOINT, or PINECONE_HOST in production
